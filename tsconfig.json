{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    // "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@styles/*": ["./app/styles/*"],
      "@app/*": ["./src/1-app/*"],
      "@pages/*": ["./src/2-pages/*"],
      "@widgets/*": ["./src/3-widgets/*"],
      "@features/*": ["./src/4-features/*"],
      "@entities/*": ["./src/5-entities/*"],
      "@shared/*": ["./src/6-shared/*"],
      "@server/*": ["./src/server/*"],
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "global.d.ts", "prisma/seed.js", "prisma/unseed.js"],
  "exclude": ["node_modules"]
}
